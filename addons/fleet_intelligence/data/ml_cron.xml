<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_ml_predictions" model="ir.cron">
            <field name="name">Fleet Intelligence: Run ML Predictions</field>
            <field name="model_id" ref="model_fleet_ml_runner"/>
            <field name="state">code</field>
            <field name="code">model.run_all_predictions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>