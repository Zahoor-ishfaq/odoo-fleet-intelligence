<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="fleet_intelligence.Dashboard">
        <div class="o_fleet_dashboard p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Fleet Intelligence</h1>
                <button class="btn btn-primary" t-on-click="refresh">
                    <i class="fa fa-refresh me-2"/>Refresh
                </button>
            </div>

            <div t-if="state.loading" class="text-center p-5">
                <i class="fa fa-spinner fa-spin fa-3x"/>
                <p class="mt-3">Loading dashboard...</p>
            </div>

            <div t-else="" class="row g-3">
                <div class="col-md-4">
                    <div class="card border-warning h-100">
                        <div class="card-body">
                            <h5 class="text-muted">Maintenance Due</h5>
                            <h1 class="display-4 text-warning">
                                <t t-esc="state.data.maintenance_due"/>
                            </h1>
                            <p class="text-muted mb-0">
                                out of <t t-esc="state.data.total_vehicles"/> vehicles
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-danger h-100">
                        <div class="card-body">
                            <h5 class="text-muted">Fuel Anomalies This Month</h5>
                            <h1 class="display-4 text-danger">
                                <t t-esc="state.data.anomaly_count"/>
                            </h1>
                            <p class="text-muted mb-0">flagged transactions</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-info h-100">
                        <div class="card-body">
                            <h5 class="text-muted">Fleet Size</h5>
                            <h1 class="display-4 text-info">
                                <t t-esc="state.data.total_vehicles"/>
                            </h1>
                            <p class="text-muted mb-0">active vehicles</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="mb-0">Top 5 Unprofitable Routes</h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Route</th>
                                        <th class="text-end">Trips</th>
                                        <th class="text-end">Total Profit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="state.data.unprofitable_routes" t-as="route" t-key="route.route">
                                        <td><t t-esc="route.route"/></td>
                                        <td class="text-end"><t t-esc="route.trips"/></td>
                                        <td class="text-end text-danger">
                                            <t t-esc="formatCurrency(route.profit)"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="mb-0">Fuel Cost Trend (Last 6 Months)</h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Month</th>
                                        <th class="text-end">Total Cost</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="state.data.cost_trend" t-as="row" t-key="row.month">
                                        <td><t t-esc="row.month"/></td>
                                        <td class="text-end">
                                            <t t-esc="formatCurrency(row.cost)"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>